# ─────────────────────────────────────────────────────────────────────────────
# blueDuck — environment variables
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# .env is loaded automatically by Docker Compose.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# AES-256-GCM key used to encrypt Git credentials stored in the database.
# Must be exactly 64 hexadecimal characters (32 bytes).
# Generate with: openssl rand -hex 32
BLUEDUCK_SECRET_KEY=

# ── Database ──────────────────────────────────────────────────────────────────

# Password for the 'blueduck' PostgreSQL user.
# The postgres service and the blueduck service both use this value.
BD_DB_PASSWORD=changeme

# ── Optional ──────────────────────────────────────────────────────────────────

# NVD API key — raises the NVD rate limit from 5 to 50 requests per 30 seconds.
# Without a key, a full CVE sync takes significantly longer.
# Get a free key at: https://nvd.nist.gov/developers/request-an-api-key
BD_NVD_API_KEY=

# Host port that the blueDuck web interface is published on (default: 8080).
# Change this if port 8080 is already in use on your machine.
BLUEDUCK_PORT=8080
